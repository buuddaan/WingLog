# Database (Postgres + PostGIS)
# Point these at your own Postgres instance.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# auth-service uses the full URL directly (schema: public)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres?sslmode=disable&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# SPRING
SPRING_PROFILES_ACTIVE=docker

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRATION=86400000

# Internal service-to-service secret
INTERNAL_SECRET=your_internal_secret

# Google OAuth (register your own client at console.cloud.google.com if you wan't to test)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Service-account JSON, base64-encoded (used by photo-service)
GOOGLE_CREDENTIALS_JSON=your_base64_encoded_service_account_json

# OAuth redirect/frontend URL (NOT hardcoded — set to your host)
OAUTH_REDIRECT_URI=http://localhost:8081/login/oauth2/code/google
APP_FRONTEND_URL=http://localhost:3000

# Cloudinary (image hosting, used by photo-service)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Mail (SMTP, used by auth-service)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true